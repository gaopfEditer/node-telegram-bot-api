# Nginx 反向代理 - Gemini API 对外暴露
# 用法: 复制到 /etc/nginx/conf.d/ 或 include 到 server 块中
# 执行: sudo cp nginx-gemini.conf.example /etc/nginx/conf.d/gemini.conf
#       修改 server_name 后: sudo nginx -t && sudo nginx -s reload

server {
    listen 80;
    # 替换为你的域名，如 api.example.com
    server_name your-domain.com;

    # 文件上传限制（与 gemini_client 10MB 一致）
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3860;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 超时（Gemini 分析可能较慢）
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }
}

